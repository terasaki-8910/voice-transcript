{
  "name": "@voice-transcript/desktop",
  "version": "0.1.6",
  "private": true,
  "description": "Tauri desktop app for Voice Transcript (Windows/Linux/macOS) -- React webview + Rust shell, sharing @voice-transcript/core via a Node sidecar.",
  "type": "module",
  "packageManager": "pnpm@11.12.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.7.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@voice-transcript/core": "workspace:*",
    "jsdom": "^29.1.1",
    "typescript": "^5.9.3",
    "vite": "^8.1.4",
    "vitest": "^3.2.7"
  }
}
