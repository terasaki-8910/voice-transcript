{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Voice Transcript",
  "version": "0.1.6",
  "identifier": "com.voicetranscript.desktop",
  "build": {
    "beforeDevCommand": "pnpm --filter @voice-transcript/core build:sidecar && pnpm dev",
    "beforeBuildCommand": "pnpm --filter @voice-transcript/core build:sidecar && pnpm build",
    "devUrl": "http://localhost:5183",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost; style-src 'self' 'unsafe-inline'"
    },
    "windows": [
      {
        "label": "main",
        "title": "Voice Transcript",
        "width": 960,
        "height": 640,
        "minWidth": 480,
        "minHeight": 420,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/core-sidecar"],
    "resources": {
      "resources/db-migrations": "db-migrations"
    }
  }
}
