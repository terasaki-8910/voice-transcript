{
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Read", "Edit", "Write",
      "Bash(git add:*)", "Bash(git commit:*)", "Bash(git checkout:*)",
      "Bash(git merge:*)", "Bash(git worktree:*)",
      "Bash(npm test:*)", "Bash(npm run:*)", "Bash(python -m pytest:*)",
      "Bash(npm install:*)", "Bash(npm ci:*)", "Bash(npx:*)", "Bash(pip install:*)"
    ],
    "deny": [
      "Bash(git push:*)", "Bash(rm -rf:*)", "WebFetch"
    ]
  }
}
