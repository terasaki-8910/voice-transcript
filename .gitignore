state/
*.log
.DS_Store
node_modules/
__pycache__/
dist/
coverage/
# secrets -- never commit. build does `git add -A`, so an untracked .env WOULD be committed.
.env
.env.*
!.env.example
# 音声ファイル
*.wav
*.mp3
*.m4a



# pipeline machinery -- kept on disk to run, NOT part of the deliverable repo
/scripts/
/prompts/
/pipeline.yaml
/Makefile
/docs/ui-rules.starter.md

# Tauri desktop app (apps/desktop) build artifacts -- regenerated, not source
**/target/
apps/desktop/dist/
apps/desktop/src-tauri/gen/
# Compiled Node sidecar -- platform-specific binaries + esbuild's intermediate
# bundle, both regenerated by `pnpm --filter core build:sidecar`, never hand-edited.
apps/desktop/src-tauri/binaries/
packages/core/.sidecar-build/
# Copied by the same build:sidecar step (see build-sidecar.mjs) from
# packages/core/src/db/migrations/, the real source of truth.
apps/desktop/src-tauri/resources/
