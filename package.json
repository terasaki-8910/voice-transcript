{
  "name": "voice-transcript",
  "version": "0.0.0",
  "private": true,
  "description": "Terminal CLI that transcribes an audio file to text via the Groq hosted Whisper API, handling files longer than one hour.",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "transcribe": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "transcribe": "tsx src/index.ts"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "eslint": "^9.18.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0",
    "vitest": "^3.0.5"
  }
}
