{
  "name": "@voice-transcript/core",
  "version": "0.0.0",
  "private": true,
  "description": "Shared transcription engine (ffmpeg normalize, silence-based chunking, Groq client, stitching, format renderers) -- no UI, no DB. Used by @voice-transcript/cli and the apps/desktop Tauri sidecar.",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts"
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src tests",
    "build:sidecar": "node scripts/build-sidecar.mjs"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "@types/pg": "^8.20.0",
    "@yao-pkg/pkg": "^6.21.0",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.1"
  }
}
